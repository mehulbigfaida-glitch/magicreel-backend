generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////////////////////////
// ENUMS
////////////////////////////////////////////////////////

enum Plan {
  FREE
  BASIC
  PRO
  ADVANCE
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

////////////////////////////////////////////////////////
// USER & BILLING
////////////////////////////////////////////////////////

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String   @map("password_hash")
  plan              Plan     @default(FREE)
  subscriptionType  BillingCycle? @map("subscription_type")
  subscriptionStart DateTime? @map("subscription_start")
  subscriptionEnd   DateTime? @map("subscription_end")

  creditsAvailable  Float    @default(0) @map("credits_available")
  rolloverCredits   Float    @default(0) @map("rollover_credits")

  freeHeroUsed      Boolean  @default(false) @map("free_hero_used")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  garments          Garment[]
  lookbooks         Lookbook[]
  p2mJobs           ProductToModelJob[]
  transactions      CreditTransaction[]
  cinematicLookbooks CinematicLookbook[]

  @@map("users")
}

model CreditTransaction {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  feature      String
  credits      Int
  type         TransactionType @default(DEBIT)
  status       TransactionStatus @default(COMPLETED)
  referenceId  String?  @map("reference_id")
  createdAt    DateTime @default(now()) @map("created_at")

  predictionId String?  @map("prediction_id")  // ✅ ADD THIS

  user         User     @relation(fields: [userId], references: [id])

  @@map("credit_transaction")
}

////////////////////////////////////////////////////////
// CORE MAGICREEL MODELS
////////////////////////////////////////////////////////

model Garment {
  id            String     @id @default(uuid())
  userId        String
  frontImageUrl String
  backImageUrl  String?
  category      String
  validated     Boolean    @default(true)
  createdAt     DateTime   @default(now())

  user          User       @relation(fields: [userId], references: [id])
  lookbooks     Lookbook[]
}

model Lookbook {
  id        String   @id @default(uuid())
  userId    String
  modelId   String
  presetId  String
  status    String
  garmentId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  garment   Garment  @relation(fields: [garmentId], references: [id])
  renders   Render[]
  edits     LookbookEdit[]
}

model Render {
  id              String   @id @default(uuid())
  pose            String
  engine          String
  modelImageUrl   String
  garmentImageUrl String
  outputImageUrl  String?
  status          String
  lookbookId      String

  // ✅ NEW (add below)
  type            String   @default("HERO") // HERO | REEL
  reelVideoUrl    String?  // for reel

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lookbook        Lookbook @relation(fields: [lookbookId], references: [id])
}

model LookbookEdit {
  id           String   @id @default(uuid())
  lookbookId   String
  elementType  String
  sourceImage  String
  resultImage  String
  createdAt    DateTime @default(now())

  lookbook     Lookbook @relation(fields: [lookbookId], references: [id])
}

model ProductToModelJob {
  id               String   @id @default(uuid())
  userId           String
  productImageUrl  String
  modelImageUrl    String
  engine           String
  engineJobId      String
  status           String
  error            String?
  resultImageUrl   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([createdAt])
}

////////////////////////////////////////////////////////
// 🎬 CINEMATIC LOOKBOOK
////////////////////////////////////////////////////////

model CinematicLookbook {
  id             String   @id @default(uuid())
  userId         String
  heroImageUrl   String
  theme          String
  seed           Int
  worldConfig    Json
  frames         Json
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ReelJob {
  id            String   @id
  status        String
  inputImageUrl String   @map("input_image_url")
  reelVideoUrl  String?  @map("reel_video_url")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("reel_jobs")
}

model Payment {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  plan              String
  amount            BigInt
  razorpayOrderId   String?  @map("razorpay_order_id")
  razorpayPaymentId String?  @unique @map("razorpay_payment_id")
  status            String
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("payments")
}